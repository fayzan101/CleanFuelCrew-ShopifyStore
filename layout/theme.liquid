<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.font_body.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}
    {% render 'css-variables' %}

    {{ content_for_header }}

    {%- liquid
      assign use_shopify_account = false
      if shop.customer_accounts_enabled
        assign use_shopify_account = true
      endif
      if routes.storefront_login_url != blank
        assign use_shopify_account = true
      endif
    -%}
    {%- if use_shopify_account -%}
      <link rel="modulepreload" href="https://cdn.shopify.com/storefront/web-components/login-form.js" crossorigin="anonymous">
      <script src="https://cdn.shopify.com/storefront/web-components/account.js" type="module" crossorigin="anonymous"></script>
    {%- endif -%}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'quick-view.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'auth-page.js' | asset_url }}" defer="defer"></script>
    <script>window.themeMoneyFormat = {{ shop.money_format | json }};</script>
    <script>
      window.themeAuth = {
        useShopifyAccount: {{ use_shopify_account | json }}
      };
    </script>
    <script>document.documentElement.className = document.documentElement.className.replace('no-js', 'js');</script>
  </head>

  <body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
    <a class="skip-to-content visually-hidden" href="#MainContent">
      {{ 'general.accessibility.skip_to_content' | t }}
    </a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'product-quick-view-modal' %}
    {% render 'wishlist-added-modal' %}

    {%- unless customer -%}
      {%- if use_shopify_account -%}
        {% render 'shopify-account-host' %}
      {%- endif -%}

      <div id="AuthModal" class="auth-modal" hidden>
        <button type="button" class="auth-modal__backdrop" data-action="close-auth-modal" aria-label="Close" tabindex="-1"></button>

        <div class="auth-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="AuthModalTitle">
          <button type="button" class="auth-modal__close" data-action="close-auth-modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>

          <div class="auth-modal__content">
            <h2 id="AuthModalTitle" class="visually-hidden">{{ 'customer.login.title' | t }}</h2>
            <div class="auth-page auth-page--compact" data-auth-root="auth-modal">
              <div class="auth-page__inner">
                {% render 'page-login', section_id: 'auth-modal', show_banner: false, compact: true, forms_only: true %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {%- endunless -%}
  </body>
</html>
