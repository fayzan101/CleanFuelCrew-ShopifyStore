<section class="testimonials" {{ section.shopify_attributes }}>
  <div class="testimonials__inner">
    <div class="testimonials__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="testimonials__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="testimonials__carousel-wrap">
      <div class="testimonials__track" id="testimonials-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="testimonials__card" {{ block.shopify_attributes }}>
            <div class="testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- assign rating = block.settings.rating | times: 1 -%}
              {%- for i in (1..5) -%}
                <svg
                  class="testimonials__star{% if i > rating %} testimonials__star--empty{% endif %}"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- endfor -%}
            </div>
            <p class="testimonials__quote">{{ block.settings.quote }}</p>
            <div class="testimonials__author">
              {%- if block.settings.avatar != blank -%}
                <img
                  src="{{ block.settings.avatar | image_url: width: 80 }}"
                  alt="{{ block.settings.name | escape }}"
                  class="testimonials__avatar"
                  loading="lazy"
                  width="40"
                  height="40"
                >
              {%- else -%}
                <div class="testimonials__avatar-placeholder">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
              <div class="testimonials__author-meta">
                <span class="testimonials__name">{{ block.settings.name }}</span>
                {%- if block.settings.date != blank -%}
                  <span class="testimonials__date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <button
        class="testimonials__nav testimonials__nav--prev"
        id="testimonials-prev-{{ section.id }}"
        aria-label="Previous review"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <button
        class="testimonials__nav testimonials__nav--next"
        id="testimonials-next-{{ section.id }}"
        aria-label="Next review"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <div class="testimonials__dots" id="testimonials-dots-{{ section.id }}"></div>
  </div>
</section>

<style>
  .testimonials {
    background: #f5ede4;
    padding: 96px 60px;
  }

  .testimonials__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .testimonials__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ternary);
    margin: 0 0 12px 0;
  }

  .testimonials__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(30px, 3.5vw, 44px);
    font-weight: 700;
    color: var(--color-secondary);
    margin: 0;
  }

  .testimonials__carousel-wrap {
    position: relative;
  }

  .testimonials__track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .testimonials__card {
    background: #fff;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .testimonials__stars {
    display: flex;
    gap: 3px;
  }

  .testimonials__star {
    color: #f4b740;
  }

  .testimonials__star--empty {
    color: #ddd;
  }

  .testimonials__quote {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.75;
    color: #4a3525;
    margin: 0;
    flex: 1;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid #f0e4d8;
  }

  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonials__avatar-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-ternary);
    color: var(--color-primary);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials__author-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonials__name {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-secondary);
  }

  .testimonials__date {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #999;
  }

  .testimonials__nav {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #fff;
    border: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-secondary);
    z-index: 2;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .testimonials__nav:hover {
    background: var(--color-secondary);
    color: var(--color-primary);
  }

  .testimonials__nav--prev {
    left: -22px;
  }
  .testimonials__nav--next {
    right: -22px;
  }

  .testimonials__dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .testimonials__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .testimonials__dot--active {
    background: var(--color-secondary);
  }

  @media (max-width: 1024px) {
    .testimonials__track {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .testimonials {
      padding: 64px 24px;
    }

    .testimonials__track {
      grid-template-columns: 1fr;
      gap: 0;
      overflow: hidden;
    }

    .testimonials__card {
      display: none;
    }

    .testimonials__card.is-active {
      display: flex;
    }

    .testimonials__nav {
      display: flex;
    }

    .testimonials__nav--prev {
      left: -8px;
    }
    .testimonials__nav--next {
      right: -8px;
    }

    .testimonials__dots {
      display: flex;
    }
  }
</style>

<script>
  (function() {
    var sectionId = {{ section.id | json }};
    var track = document.getElementById('testimonials-track-' + sectionId);
    var dotsWrap = document.getElementById('testimonials-dots-' + sectionId);
    var prevBtn = document.getElementById('testimonials-prev-' + sectionId);
    var nextBtn = document.getElementById('testimonials-next-' + sectionId);

    if (!track) return;

    var cards = Array.from(track.querySelectorAll('.testimonials__card'));
    var current = 0;

    function isMobile() {
      return window.innerWidth <= 768;
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      cards.forEach(function(_, i) {
        var dot = document.createElement('button');
        dot.className = 'testimonials__dot' + (i === current ? ' testimonials__dot--active' : '');
        dot.setAttribute('aria-label', 'Go to review ' + (i + 1));
        dot.addEventListener('click', function() { goTo(i); });
        dotsWrap.appendChild(dot);
      });
    }

    function goTo(index) {
      if (!isMobile()) return;
      cards[current].classList.remove('is-active');
      current = (index + cards.length) % cards.length;
      cards[current].classList.add('is-active');
      var dots = dotsWrap.querySelectorAll('.testimonials__dot');
      dots.forEach(function(d, i) {
        d.classList.toggle('testimonials__dot--active', i === current);
      });
    }

    function init() {
      if (isMobile()) {
        cards[current].classList.add('is-active');
        buildDots();
      }
    }

    prevBtn.addEventListener('click', function() { goTo(current - 1); });
    nextBtn.addEventListener('click', function() { goTo(current + 1); });

    window.addEventListener('resize', function() {
      if (!isMobile()) {
        cards.forEach(function(c) { c.classList.remove('is-active'); });
      } else {
        cards[current].classList.add('is-active');
        buildDots();
      }
    });

    init();
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-index-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
