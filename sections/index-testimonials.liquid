<section class="testimonials" {{ section.shopify_attributes }}>
  {%- assign has_app_block = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == '@app' or block.type contains 'shopify://apps/' -%}
      {%- assign has_app_block = true -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="testimonials__inner">
    <div class="testimonials__left">
      {%- if section.settings.eyebrow != blank -%}
        <p class="testimonials__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__heading">{{ section.settings.heading }}<em>{{ section.settings.heading_italic }}</em></h2>
      {%- endif -%}
      <div class="testimonials__nav">
        <button
          class="testimonials__nav-btn testimonials__nav-btn--prev"
          id="testimonials-prev-{{ section.id }}"
          aria-label="Previous reviews"
        >
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="4"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button
          class="testimonials__nav-btn testimonials__nav-btn--next"
          id="testimonials-next-{{ section.id }}"
          aria-label="Next reviews"
        >
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="4"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="testimonials__right">
      {%- if has_app_block -%}
        <div class="testimonials__app-widget">
          {%- for block in section.blocks -%}
            {%- if block.type == '@app' or block.type contains 'shopify://apps/' -%}
              <div class="testimonials__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="testimonials__viewport" id="testimonials-viewport-{{ section.id }}">
          <div class="testimonials__track" id="testimonials-track-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- assign rating = block.settings.rating | times: 1 -%}
              <div class="testimonials__card" {{ block.shopify_attributes }}>
                <div class="testimonials__author">
                  {%- if block.settings.avatar != blank -%}
                    <img
                      src="{{ block.settings.avatar | image_url: width: 80 }}"
                      alt="{{ block.settings.name | escape }}"
                      class="testimonials__avatar"
                      loading="lazy"
                      width="40"
                      height="40"
                    >
                  {%- else -%}
                    <span class="testimonials__avatar-placeholder" aria-hidden="true">
                      <svg
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
                      </svg>
                    </span>
                  {%- endif -%}
                  <span class="testimonials__name">{{ block.settings.name }}</span>
                </div>

                <div class="testimonials__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    <svg
                      class="testimonials__star{% if i > rating %} testimonials__star--empty{% endif %}"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- endfor -%}
                </div>

                <p class="testimonials__quote-text">{{ block.settings.quote }}</p>
                <button class="testimonials__toggle" type="button" hidden>Read more</button>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-image: url('{{ "Index-testimonials-bg.png" | asset_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 96px 0 96px 60px;
  }

  .testimonials__inner {
    width: 100%;
    margin: 0;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 10em;
    align-items: center;
  }

  .testimonials__eyebrow {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ternary);
    margin: 0 0 12px 0;
  }

  .testimonials__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(30px, 3.6vw, 50px);
    font-weight: 500;
    color: var(--color-secondary);
    margin: 0 0 32px 0;
    line-height: 1.2;
  }
  .testimonials__heading em {
    font-style: italic;
    font-weight: 600;
    color: var(--color-ternary);
  }

  .testimonials__nav {
    display: flex;
    gap: 20px;
  }

  .testimonials__nav-btn {
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    appearance: none;
    -webkit-appearance: none;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-secondary);
    transition: transform 0.2s ease;
    padding: 0;
  }

  .testimonials__nav-btn:hover {
    transform: scale(1.25);
  }
  .testimonials__nav-btn.is-hidden {
    visibility: hidden;
    pointer-events: none;
  }

  /* Right side - carousel */
  .testimonials__right {
    min-width: 0;
    padding-right: 20px;
    box-sizing: border-box;
  }

  .testimonials__app-widget {
    width: 100%;
  }

  .testimonials__app-block {
    width: 100%;
  }

  .testimonials__viewport {
    width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
  }

  .testimonials__track {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding-top: 12px;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .testimonials__card {
    flex: 0 0 334px;
    width: 322px;
    height: 220px;
    box-sizing: border-box;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 4px 18px rgba(74, 53, 37, 0.08);
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, height 0.25s ease;
    overflow: hidden;
  }

  .testimonials__card.is-expanded {
    height: auto;
  }

  .testimonials__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 28px rgba(74, 53, 37, 0.14);
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonials__avatar-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid black;
    color: black;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials__name {
    font-family: var(--font-heading-family);
    font-size: 17px;
    font-weight: 700;
    color: black;
  }

  .testimonials__stars {
    display: flex;
  }

  .testimonials__star {
    color: #feb42f;
  }

  .testimonials__star--empty {
    color: #ddd;
  }

  .testimonials__quote-text {
    font-family: var(--font-body-family);
    font-size: 16px;
    line-height: 1.4em;
    color: black;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .testimonials__card.is-expanded .testimonials__quote-text {
    -webkit-line-clamp: unset;
    display: block;
    overflow: visible;
  }

  .testimonials__toggle {
    align-self: flex-start;
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 600;
    color: #999;
    text-decoration: underline;
    cursor: pointer;
  }

  .testimonials__toggle:hover {
    color: var(--color-secondary);
  }

  @media (max-width: 1024px) {
    .testimonials__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .testimonials__viewport {
      width: 100%;
    }

    .testimonials__card {
      flex: 0 0 calc((100% - 24px) / 2);
      width: auto;
    }
    .testimonials__right {
      padding-right: 0;
    }
  }

  @media (max-width: 640px) {
    .testimonials {
      padding: 64px 24px;
    }

    .testimonials__card {
      flex: 0 0 100%;
    }
  }
</style>

{%- unless has_app_block -%}
<script>
  (function() {
    var sectionId = {{ section.id | json }};
    var viewport = document.getElementById('testimonials-viewport-' + sectionId);
    var track = document.getElementById('testimonials-track-' + sectionId);
    var prevBtn = document.getElementById('testimonials-prev-' + sectionId);
    var nextBtn = document.getElementById('testimonials-next-' + sectionId);

    if (!track) return;

    var cards = Array.from(track.querySelectorAll('.testimonials__card'));
    if (!cards.length) return;

    var index = 0;
    var autoplayTimer = null;
    var AUTOPLAY_MS = 4500;

    function visibleCount() {
      var trackWidth = track.parentElement.clientWidth;
      var cardWidth = cards[0].getBoundingClientRect().width;
      var gap = parseFloat(getComputedStyle(track).gap) || 0;
      var count = Math.floor((trackWidth + gap) / (cardWidth + gap));
      return Math.max(1, count);
    }

    function maxIndex() {
      return Math.max(0, cards.length - visibleCount());
    }

    function step() {
      var card = cards[0];
      var gap = parseFloat(getComputedStyle(track).gap) || 0;
      return card.getBoundingClientRect().width + gap;
    }

    function update() {
      var max = maxIndex();
      if (index > max) index = max;
      if (index < 0) index = 0;

      track.style.transform = 'translateX(-' + (step() * index) + 'px)';

      prevBtn.classList.toggle('is-hidden', index <= 0);
      nextBtn.classList.toggle('is-hidden', index >= max);
    }

    function goTo(newIndex) {
      index = newIndex;
      update();
    }

    function next() {
      var max = maxIndex();
      if (index >= max) {
        goTo(0);
      } else {
        goTo(index + 1);
      }
    }

    function prev() {
      goTo(index - 1);
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(next, AUTOPLAY_MS);
    }

    function stopAutoplay() {
      if (autoplayTimer) clearInterval(autoplayTimer);
      autoplayTimer = null;
    }

    prevBtn.addEventListener('click', function() {
      prev();
      startAutoplay();
    });

    nextBtn.addEventListener('click', function() {
      next();
      startAutoplay();
    });

    viewport.addEventListener('mouseenter', stopAutoplay);
    viewport.addEventListener('mouseleave', startAutoplay);

    window.addEventListener('resize', function() {
      update();
    });

    cards.forEach(function(card) {
      var quote = card.querySelector('.testimonials__quote-text');
      var toggle = card.querySelector('.testimonials__toggle');

      function checkOverflow() {
        var isOverflowing = quote.scrollHeight > quote.clientHeight + 1;
        if (isOverflowing || card.classList.contains('is-expanded')) {
          toggle.hidden = false;
        } else {
          toggle.hidden = true;
        }
      }

      toggle.addEventListener('click', function() {
        var expanded = card.classList.toggle('is-expanded');
        toggle.textContent = expanded ? 'Hide' : 'Read more';
        update();
      });

      window.requestAnimationFrame(checkOverflow);
      window.addEventListener('resize', checkOverflow);
    });

    update();
    startAutoplay();
  })();
</script>
{%- endunless -%}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-index-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Testimonial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Client's Success "
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading italic text",
      "default": "Stories"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar image",
          "info": "Leave blank to use the default person icon"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Patricia Raphael"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star rating"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "I just tried the spread this morning. It was really nice — not sweet at all! I had both the pistachio and choco hazelnut mixed in a sandwich and it was amazing."
        }
      ]
    }
  ],
  "presets": [
