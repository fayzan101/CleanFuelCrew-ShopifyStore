<header class="header" role="banner" {{ section.shopify_attributes }}>
  <div class="page-width header__inner" style="--logo-width: {{ settings.logo_width }}px;">
    <div class="header__left">
      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if settings.logo != blank -%}
          {{
            settings.logo
            | image_url: width: settings.logo_width
            | image_tag: alt: shop.name, widths: '100, 200, 300'
          }}
        {%- else -%}
          <img src="{{ 'Logo.png' | asset_url }}" alt="{{ shop.name }}" class="header__logo-fallback" height="80" width="80">
        {%- endif -%}
      </a>

      <button
        type="button"
        class="header__menu-toggle"
        data-action="toggle-menu"
        aria-controls="HeaderNav"
        aria-expanded="false"
        aria-label="Open menu"
      >
        <span class="header__menu-icon" aria-hidden="true"></span>
      </button>
    </div>

    <nav class="header__nav-wrapper" id="HeaderNav" aria-label="{{ 'sections.header.menu' | t }}">
      <button
        type="button"
        class="header__menu-close"
        data-action="toggle-menu"
        aria-label="Close menu"
      >
        <span class="header__close-icon" aria-hidden="true"></span>
      </button>

      <ul class="header__nav" role="list">
        {% render 'site-nav-links', menu: section.settings.menu %}
      </ul>
    </nav>

    <div class="header__right">
      <div class="header__icons">
        <a href="{{ routes.search_url }}" class="header__icon-link" aria-label="{{ 'general.search.search' | t }}">
          <span class="header__icon-img" style="--icon-url: url('{{ 'search.svg' | asset_url }}');"></span>
        </a>
        <a href="{{ pages.wishlist.url | default: '/pages/wishlist' }}" class="header__icon-link header__wishlist" aria-label="Wishlist">
          {% render 'icon-heart' %}
          <span class="wishlist-count" data-wishlist-count hidden>0</span>
        </a>
        <a href="{{ routes.cart_url }}" class="header__icon-link header__cart" id="cart-icon-bubble" aria-label="{{ 'sections.header.cart' | t }}">
          <span class="header__icon-img" style="--icon-url: url('{{ 'cart.svg' | asset_url }}');"></span>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
        <a href="{{ routes.account_url }}" class="header__icon-link" aria-label="Account">
          <span class="header__icon-img" style="--icon-url: url('{{ 'profile.svg' | asset_url }}');"></span>
        </a>
      </div>
    </div>
  </div>

  <button type="button" class="header__overlay" data-action="toggle-menu" aria-label="Close menu" tabindex="-1"></button>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
