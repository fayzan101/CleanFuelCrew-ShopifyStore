<div class="section search-page" {{ section.shopify_attributes }}>
  {% render 'page-banner',
    banner_title: 'Search',
    banner_subtitle: section.settings.banner_subtitle | default: 'Home / Search',
    banner_image: section.settings.banner_image
  %}

  <div class="page-width-larger search-page__inner">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
      <label class="visually-hidden" for="SearchInput-{{ section.id }}">{{ 'general.search.search' | t }}</label>
      <input
        type="search"
        name="q"
        id="SearchInput-{{ section.id }}"
        class="search-page__input"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.search' | t }}"
      >
      <button type="submit" class="button search-page__submit">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- paginate search.results by 12 -%}
        {%- if search.results_count > 0 -%}
          <p class="search-page__count">
            {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
          </p>

          <ul class="product-grid product-grid--shop" role="list">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                <li class="product-grid__item">
                  {% render 'card-product-shop', card_product: item %}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            {% render 'pagination', paginate: paginate %}
          {%- endif -%}
        {%- else -%}
          <p class="search-page__empty">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search",
  "settings": [
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner subtitle",
      "default": "Home / Search"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    }
  ]
}
{% endschema %}
