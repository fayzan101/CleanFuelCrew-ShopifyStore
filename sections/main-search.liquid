<div class="section search" {{ section.shopify_attributes }}>
  <div class="page-width">
    <h1>{{ 'general.search.search' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <div class="field">
        <label for="SearchInput-{{ section.id }}" class="visually-hidden">{{ 'general.search.search' | t }}</label>
        <input
          type="search"
          name="q"
          id="SearchInput-{{ section.id }}"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.search' | t }}"
        >
      </div>
      <button type="submit" class="button">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p>
          {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
        </p>
        <ul class="product-grid" role="list">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <li>{% render 'card-product', card_product: item %}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p>{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search",
  "settings": []
}
{% endschema %}
