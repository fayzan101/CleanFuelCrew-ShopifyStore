<footer class="footer" role="contentinfo" style="background-image: url('{{ 'footer-bg.png' | asset_url }}');" {{ section.shopify_attributes }}>
  <div class="page-width footer__inner">
    <div class="footer__top">
      <div class="footer__brand footer__panel">
        <p class="footer__eyebrow">Naturally sweetened snacks</p>
        <a href="{{ routes.root_url }}" class="footer__logo">
          {%- if settings.logo != blank -%}
            {{ settings.logo | image_url: width: 180 | image_tag: alt: shop.name }}
          {%- else -%}
            <img src="{{ 'Logo.png' | asset_url }}" alt="{{ shop.name }}" class="header__logo-fallback" height="80" width="80" />
          {%- endif -%}
        </a>
        <p class="footer__desc">{{ shop.meta_description | default: 'The Clean Fuel Crew crafts naturally sweetened, clean-label snacks you can enjoy every day. Made with real ingredients, never refined sugar or artificial additives.' }}</p>
        <div class="footer__brand-actions">
          <a href="{{ routes.all_products_collection_url }}" class="footer__cta">Shop all products</a>
          <a href="https://www.instagram.com/thecleanfuelcrew/" class="footer__social-link" aria-label="Instagram">
            <span class="footer__social-icon" style="--icon-url: url('{{ 'insta.svg' | asset_url }}');"></span>
            <span>Follow us</span>
          </a>
        </div>
      </div>

      <div class="footer__cols">
        <div class="footer__col footer__panel">
          <h4 class="footer__col-title">Quick Links</h4>
          <ul>
            {% render 'site-nav-links', menu: section.settings.menu %}
          </ul>
        </div>

        <div class="footer__col footer__panel">
          <h4 class="footer__col-title">Products</h4>
          <ul>
            {%- liquid
              assign footer_collection = nil
              if section.settings.products_collection != blank and section.settings.products_collection.products_count > 0
                assign footer_collection = section.settings.products_collection
              elsif collections.all.products_count > 0
                assign footer_collection = collections.all
              elsif collections.frontpage.products_count > 0
                assign footer_collection = collections.frontpage
              endif
            -%}
            {%- if footer_collection != blank -%}
              {%- for product in footer_collection.products limit: section.settings.products_to_show -%}
                <li><a href="{{ product.url }}">{{ product.title | escape }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="{{ routes.all_products_collection_url }}">View all products</a></li>
            {%- endif -%}
          </ul>
        </div>

        <div class="footer__col footer__panel">
          <h4 class="footer__col-title">Get in Touch</h4>
          <a class="footer__contact-link" href="mailto:thecleanfuelcrew@gmail.com">thecleanfuelcrew@gmail.com</a>
          <div class="footer__social-block">
            <h5 class="footer__col-title">Follow Us On</h5>
            <a href="https://www.instagram.com/thecleanfuelcrew/" aria-label="Instagram">
              <span class="footer__social-icon" style="--icon-url: url('{{ 'insta.svg' | asset_url }}');"></span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p class="footer__credit">{{ section.settings.credit }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "section-footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Same links as the header navigation"
    },
    {
      "type": "collection",
      "id": "products_collection",
      "label": "Products column collection",
      "info": "Leave empty to use all products automatically"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "credit",
      "label": "Theme Credit",
      "default": "Handcrafted with love in the UAE"
    }
  ]
}
{% endschema %}
