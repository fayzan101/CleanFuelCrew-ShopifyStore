<section class="why-dates" {{ section.shopify_attributes }}>
  <div class="why-dates__inner">
    <div class="why-dates__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="why-dates__heading">
          {{ section.settings.heading }}
          <em>{{ section.settings.heading_italic }}</em>
        </h2>
      {%- endif -%}
    </div>

    <div class="why-dates__stack">
      {%- for block in section.blocks -%}
        {%- liquid
          assign stack_top = section.settings.stack_offset | times: forloop.index0 | plus: section.settings.stack_base_offset
        -%}
        <div
          class="why-dates__card"
          style="top: {{ stack_top }}px; z-index: {{ forloop.index }};"
          {{ block.shopify_attributes }}
        >
          <div class="why-dates__card-inner">
            <div class="why-dates__item-text">
              <span class="why-dates__number">{{ forloop.index | prepend: '0' }}</span>
              <h3 class="why-dates__item-heading">{{ block.settings.heading }}</h3>
              <div class="why-dates__item-body">{{ block.settings.body }}</div>
            </div>
            <div class="why-dates__item-image">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag: loading: 'lazy', alt: block.settings.heading
                }}
              {%- elsif block.settings.default_asset != blank -%}
                <img
                  src="{{ block.settings.default_asset | asset_url }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="600"
                  height="500"
                >
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }},
  .section-index-why-dates {
    overflow: visible !important;
  }
  .why-dates {
    background: var(--color-primary);
    padding: 0 60px;
    overflow: visible !important;
  }

  .why-dates__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .why-dates__header {
    margin-bottom: 56px;
    text-align: center;
  }

  .why-dates__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(30px, 5vw, 50px);
    font-weight: 550;
    color: var(--color-secondary);
    margin: 0;
  }

  .why-dates__heading em {
    font-style: italic;
    font-weight: 500;
    color: var(--color-ternary);
  }

    /* ---- Stacking cards ---- */

    .why-dates__stack {
      position: relative;
      display: flex;
      width: 100%;
      padding: 40px;
      flex-direction: column;
      overflow: visible !important;
    }
    .why-dates__card {
      position: -webkit-sticky;
    position: sticky;
    margin-bottom: 64px;
    }

    .why-dates__card-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 70px;
    align-items: center;
    background: var(--color-primary);
    border-radius: {{ section.settings.card_radius }}px;
    box-shadow: 0 -15px 40px -10px rgba(0,0,0,0.12);
    padding: 48px;
  }

  .why-dates__item-text {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

    .why-dates__number {
    font-family: var(--font-body-family);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-secondary);
    opacity: 0.45;
    letter-spacing: 0.05em;
  }

  .why-dates__item-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(26px, 2.8vw, 36px);
    font-weight: 500;
    color: var(--color-secondary);
    margin: 10px 0;
  }

    .why-dates__item-body {
    font-family: var(--font-body-family);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text);
    opacity: 0.7;
  }

  .why-dates__item-body p {
    margin: 0;
    mx-width: 400px;
  }

  .why-dates__item-image img {
    width: 420px;
    height: 280px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

    @media (max-width: 768px) {
    .why-dates {
      padding: 0px 24px;
    }
    .why-dates__stack {
      padding: 40px 0;
    }

    .why-dates__header {
      flex-direction: column;
      gap: 16px;
    }

    .why-dates__heading-sub,
    .why-dates__intro {
      text-align: left;
      max-width: none;
    }

    .why-dates__card-inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px 15px;
    }

    .why-dates__item-image {
      order: -1;
    }

    .why-dates__item-image img {
      height: 260px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .why-dates__card {
      position: static;
      margin-bottom: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Why Dates",
  "tag": "section",
  "class": "section-index-why-dates",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic part)",
      "default": "Momentum"
    },
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "padding_block",
      "label": "Section vertical padding (px)",
      "min": 32,
      "max": 160,
      "step": 4,
      "default": 96
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Space below header (px)",
      "min": 24,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "stack_base_offset",
      "label": "First card sticky offset (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "stack_offset",
      "label": "Offset increment per card (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "body", "label": "Body text" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "default_asset", "label": "Fallback asset filename (used if no image picked)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Dates",
      "blocks": [
        {
          "type": "reason",
          "settings": {
            "heading": "Morning Momentum",
            "default_asset": "Index-Morning-momentum.png"
          }
        },
        {
          "type": "reason",
          "settings": {
            "heading": "All Day Run & Hustle",
            "default_asset": "Index-Run-Hustle.png"
          }
        },
        {
          "type": "reason",
          "settings": {
            "heading": "Post-Game Glow",
            "default_asset": "Index-Post-game.png"
          }
        },
        {
          "type": "reason",
          "settings": {
            "heading": "Fueling Our Community, One Event at a Time",
            "default_asset": "Index-Fueling-Community.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
