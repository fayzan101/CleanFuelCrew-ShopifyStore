<div class="section collection-page" {{ section.shopify_attributes }}>
  {% render 'page-banner',
    banner_title: section.settings.banner_title | default: collection.title,
    banner_subtitle: section.settings.banner_subtitle | default: 'Home / Shop',
    banner_image: section.settings.banner_image | default: collection.featured_image
  %}

  <div class="page-width-larger collection-page__inner">
    <div class="collection-page__layout">
      <div class="collection-page__main">
        {%- paginate collection.products by section.settings.products_per_page -%}
          <div class="collection-toolbar">
            <p class="collection-toolbar__count" data-collection-count data-default-count="Showing all {{ collection.products_count }} result{% if collection.products_count != 1 %}s{% endif %}">
              Showing all {{ collection.products_count }} result{% if collection.products_count != 1 %}s{% endif %}
            </p>

            <div class="collection-toolbar__sort">
              <label class="visually-hidden" for="SortBy-{{ section.id }}">Sort by</label>
              <select
                id="SortBy-{{ section.id }}"
                class="collection-toolbar__sort-select"
                data-action="collection-sort"
              >
                {%- for option in collection.sort_options -%}
                  <option
                    value="{{ option.value }}"
                    {% if option.value == collection.sort_by %}selected{% endif %}
                  >
                    {{ option.name }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          </div>

          {%- if collection.products.size > 0 -%}
            <ul class="product-grid product-grid--shop" role="list" data-collection-grid>
              {%- for product in collection.products -%}
                <li
                  class="product-grid__item"
                  data-product-item
                  data-product-title="{{ product.title | escape }}"
                  data-product-type="{{ product.type | escape }}"
                  data-product-category-id="{{ product.category.id | default: '' | escape }}"
                  data-product-category-name="{{ product.category.name | default: '' | escape }}"
                >
                  {% render 'card-product-shop', card_product: product %}
                </li>
              {%- endfor -%}
            </ul>
            <p class="collection-page__empty" data-collection-search-empty hidden>No products found.</p>
          {%- else -%}
            <p class="collection-page__empty">{{ 'collections.general.no_matches' | t }}</p>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            <div data-collection-pagination>
              {% render 'pagination', paginate: paginate %}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

      {% render 'collection-sidebar', section: section, collection: collection %}
    </div>
  </div>

  {%- if section.settings.whatsapp_url != blank -%}
    <a href="{{ section.settings.whatsapp_url }}" class="collection-whatsapp" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    {
      "type": "text",
      "id": "banner_title",
      "label": "Banner title",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner subtitle",
      "default": "Home / Shop"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 48,
      "step": 3,
      "default": 9,
      "label": "Products per page"
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "checkbox",
      "id": "show_categories",
      "label": "Show categories",
      "default": true,
      "info": "Shows Product type and Product category from your store. Enable both filters in Search & Discovery for the full list."
    },
    {
      "type": "checkbox",
      "id": "show_price_filter",
      "label": "Show price filter",
      "default": true
    },
    {
      "type": "number",
      "id": "price_filter_min",
      "label": "Price filter minimum",
      "default": 10
    },
    {
      "type": "number",
      "id": "price_filter_max",
      "label": "Price filter maximum",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "show_popular",
      "label": "Show popular products",
      "default": true
    },
    {
      "type": "text",
      "id": "popular_heading",
      "label": "Popular products heading",
      "default": "Popular products"
    },
    {
      "type": "collection",
      "id": "popular_collection",
      "label": "Popular products collection"
    },
    {
      "type": "range",
      "id": "popular_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Popular products to show"
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp chat link",
      "info": "e.g. https://wa.me/971500000000"
    }
  ]
}
{% endschema %}
