<div class="section collection" {{ section.shopify_attributes }}>
  {% render 'page-banner',
    banner_title: collection.title,
    banner_subtitle: section.settings.banner_subtitle | default: 'Home / Shop',
    banner_image: section.settings.banner_image | default: collection.featured_image
  %}

  <div class="page-width">
    <h1>{{ collection.title | escape }}</h1>

    {%- if collection.description != blank -%}
      <div class="collection__description rte">{{ collection.description }}</div>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <ul class="product-grid" role="list">
          {%- for product in collection.products -%}
            <li>
              {% render 'card-product', card_product: product %}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p>{{ 'collections.general.no_matches' | t }}</p>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate: paginate %}
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "class": "section-main-collection",
  "settings": [
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner subtitle",
      "default": "Home / Shop"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
