{%- if section.settings.text != blank -%}
  <div
    class="announcement-bar"
    role="region"
    aria-label="{{ 'sections.announcement_bar.name' | t }}"
    {{ section.shopify_attributes }}
  >
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>
    {%- else -%}
      <p>{{ section.settings.text | escape }}</p>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "tag": "section",
  "class": "section-announcement",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Welcome to our store"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.name"
    }
  ]
}
{% endschema %}
