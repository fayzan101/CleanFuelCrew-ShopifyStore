<section class="hero" {{ section.shopify_attributes }}>
  <div class="hero__background">
    {%- if section.settings.background_image != blank -%}
      {%- assign hero_img_src = section.settings.background_image | image_url: width: 1800 -%}
    {%- else -%}
      {%- assign hero_img_src = 'index-banner.png' | asset_url -%}
    {%- endif -%}
    <img
      src="{{ hero_img_src }}"
      alt="Hero background"
      class="hero__bg-img"
      loading="eager"
      width="1800"
      height="900"
    >
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <div class="hero__buttons">
      {%- if section.settings.primary_label != blank -%}
        <a href="{{ section.settings.primary_url | default: '/collections/all' }}" class="btn btn--primary">
          {{ section.settings.primary_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.secondary_label != blank -%}
        <a href="{{ section.settings.secondary_url | default: '/pages/about' }}" class="btn btn--secondary">
          {{ section.settings.secondary_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    position: relative;
    top: 30px;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    top: -20px;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(92, 61, 46, 0.72) 0%,
      rgba(92, 61, 46, 0.35) 55%,
      rgba(92, 61, 46, 0.05) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    padding: 80px 60px;
    color: var(--color-primary);
    margin: 60px 0 0 60px;
  }

  .hero__eyebrow {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 16px 0;
  }

  .hero__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(52px, 5vw, 88px);
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: var(--color-primary);
  }

  .hero__subtext {
    font-family: var(--font-body-family);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-primary);
    margin: 0 0 40px 0;
    max-width: 480px;
  }

  .hero__buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    font-family: var(--font-body-family);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 32px;
    transition: background 0.2s ease, color 0.2s ease;
    vertical-align: middle;
  }

  .btn--primary {
    background: var(--color-primary);
    color: var(--color-secondary);
  }

  .btn--primary:hover {
    background: var(--color-secondary);
    color: var(--color-primary);
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn--secondary:hover {
    background: var(--color-secondary);
    color: var(--color-primary);
    border-color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .hero {
      display: flex;
      align-items: flex-end;
      min-height: 480px;
      top: 0;
    }

    .hero__background {
      position: absolute;
      inset: 0;
    }

    .hero__bg-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }

    .hero__overlay {
      background: linear-gradient(
        to top,
        rgba(92, 61, 46, 0.72) 0%,
        rgba(92, 61, 46, 0.35) 55%,
        rgba(92, 61, 46, 0.05) 100%
      );
    }

    .hero__content {
      position: relative;
      z-index: 1;
      max-width: 100%;
      padding: 1.6rem 1.6rem 2rem;
      margin: 0;
    }

    .hero__eyebrow {
      font-size: 1.1rem;
      letter-spacing: 0.1em;
      margin-bottom: 0.8rem;
    }

    .hero__heading {
      font-size: clamp(2.4rem, 6vw, 3.4rem);
      margin-bottom: 1rem;
    }

    .hero__subtext {
      font-size: 1.3rem;
      line-height: 1.5;
      margin-bottom: 1.4rem;
      max-width: 100%;
    }

    .hero__buttons {
      gap: 0.8rem;
    }

    .btn {
      padding: 1rem 1.6rem;
      font-size: 1.15rem;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-index-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Leave blank to use the default image from assets"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Handcrafted in Dubai."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sweetened by Nature."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Premium nut spreads powered by dates. No refined sugar. No gluten. No dairy. Just rich flavour, honest ingredients, and energy that goes the distance."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
