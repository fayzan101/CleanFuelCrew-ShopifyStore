{%- comment -%}
  Router only — picks the page snippet by handle. Each snippet handles its own banner.
{%- endcomment -%}

{%- case page.handle -%}
  {%- when 'about' -%}
    {%- comment -%}
      For full theme editor controls (banner image, story, mission, founder),
      assign the "about" template to this page: Pages → About → Theme template → about
    {%- endcomment -%}
    {% render 'page-about', shopify_attributes: section.shopify_attributes %}

  {%- when 'wishlist' -%}
    {% render 'page-wishlist', shopify_attributes: section.shopify_attributes %}

  {%- when 'shipping-returns' -%}
    {% render 'page-shipping-returns',
      shopify_attributes: section.shopify_attributes,
      banner_image: section.settings.banner_image
    %}

  {%- when 'contact' -%}
    {% render 'page-contact',
      shopify_attributes: section.shopify_attributes,
      section_id: section.id,
      banner_page_title: page.title | default: 'Contact',
      banner_subtitle: section.settings.banner_subtitle | default: 'Home / Contact',
      banner_image: section.settings.banner_image
    %}

  {%- else -%}
    {% render 'page-default', section: section, shopify_attributes: section.shopify_attributes %}
{%- endcase -%}

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page",
  "settings": [
    {
      "type": "paragraph",
      "content": "For the About page, use the 'about' page template (Pages → About → Theme template → about) to edit all content in the theme customizer. Banner settings below apply to generic pages only."
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show page banner",
      "default": true
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner subtitle",
      "default": "Home / Page"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    }
  ]
}
{% endschema %}
