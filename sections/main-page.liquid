{%- comment -%}
  Router only — picks the page snippet by handle. Each snippet handles its own banner.
{%- endcomment -%}

{%- case page.handle -%}
  {%- when 'about' -%}
    {% render 'page-about', shopify_attributes: section.shopify_attributes %}

  {%- when 'recipes' -%}
    {% render 'page-recipes', shopify_attributes: section.shopify_attributes %}

  {%- when 'wishlist' -%}
    {% render 'page-wishlist', shopify_attributes: section.shopify_attributes %}

  {%- when 'shipping-returns' -%}
    {% render 'page-shipping-returns', shopify_attributes: section.shopify_attributes %}

  {%- else -%}
    {% render 'page-default', section: section, shopify_attributes: section.shopify_attributes %}
{%- endcase -%}

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page",
  "settings": [
    {
      "type": "paragraph",
      "content": "Banner settings below apply to generic pages only. About, Recipes, Wishlist, and Shipping & Returns control their own layout in snippets."
    },
    {
      "type": "checkbox",
      "id": "show_banner",
      "label": "Show page banner",
      "default": true
    },
    {
      "type": "text",
      "id": "banner_subtitle",
      "label": "Banner subtitle",
      "default": "Home / Page"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    }
  ]
}
{% endschema %}
