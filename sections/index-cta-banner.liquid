<section class="cta-banner" {{ section.shopify_attributes }}>
  <div class="cta-banner__background">
    {%- if section.settings.background_image != blank -%}
      {%- assign cta_img_src = section.settings.background_image | image_url: width: 1800 -%}
    {%- else -%}
      {%- assign cta_img_src = 'Index-CTA-bg.png' | asset_url -%}
    {%- endif -%}
    <img
      src="{{ cta_img_src }}"
      alt=""
      class="cta-banner__bg-img"
      loading="lazy"
      width="1800"
      height="700"
    >
    <div class="cta-banner__overlay"></div>
  </div>

  <div class="cta-banner__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="cta-banner__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="cta-banner__heading">
        {%- assign parts = section.settings.heading | split: '|' -%}
        {{ parts[0] -}}
        <em>{{ parts[1] }}</em>{{ parts[2] }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="cta-banner__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="cta-banner__btn">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .cta-banner {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  .cta-banner__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-banner__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .cta-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(92, 61, 46, 0.58);
  }

  .cta-banner__content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    padding: 60px 40px;
    color: var(--color-primary);
    align-self: center;
  }

  .cta-banner__eyebrow {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ternary);
    margin: 0 0 16px 0;
  }

  .cta-banner__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 5rem, 6.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px 0;
    color: var(--color-primary);
    text-align: center;
  }

  .cta-banner__heading em {
    font-style: italic;
    color: var(--color-ternary);
  }

  .cta-banner__subtext {
    font-family: var(--font-body-family);
    font-size: 16px;
    line-height: 1.7;
    color: rgba(253, 246, 238, 0.85);
    margin: 0 0 40px 0;
  }

  .cta-banner__btn {
    display: inline-block;
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 40px;
    background: var(--color-ternary);
    color: var(--color-primary);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .cta-banner__btn:hover {
    background: var(--color-primary);
    color: var(--color-secondary);
  }

  @media (max-width: 768px) {
    .cta-banner {
      min-height: 420px;
    }

    .cta-banner__content {
      padding: 48px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "CTA Banner",
  "tag": "section",
  "class": "section-index-cta-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Leave blank to use the default image from assets"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Ready to taste the difference?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every\n Spoonful |Tells\n a Story|"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "From our kitchen to your table — pure ingredients, honest flavors, and the kind of goodness you can feel."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL",
      "info": "Leave blank to default to /collections/all"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
