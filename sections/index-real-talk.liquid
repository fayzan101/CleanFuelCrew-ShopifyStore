<section class="real-talk" {{ section.shopify_attributes }}>
  <div class="real-talk__inner">
    <div class="real-talk__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="real-talk__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="real-talk__heading">
          {{ section.settings.heading }}
          <em>{{ section.settings.heading_italic }}</em>
        </h2>
      {%- endif -%}
    </div>

    <div class="real-talk__grid">
      {%- for block in section.blocks -%}
        <div class="real-talk__card" {{ block.shopify_attributes }}>
          <div class="real-talk__card-image">
            {%- if block.settings.image != blank -%}
              {%- assign rt_img_src = block.settings.image | image_url: width: 308 -%}
            {%- else -%}
              {%- assign rt_img_src = block.settings.default_asset | asset_url -%}
            {%- endif -%}
            <img
              src="{{ rt_img_src }}"
              alt="{{ block.settings.heading | escape }}"
              loading="lazy"
              width="308"
              height="308"
            >
          </div>
          <div class="real-talk__card-body">
            {%- if block.settings.heading != blank -%}
              <h3 class="real-talk__card-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="real-talk__card-body-text">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .real-talk {
    padding: 96px 60px;
  }

  .real-talk__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .real-talk__header {
    margin-bottom: 56px;
    text-align: center;
  }

  .real-talk__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ternary);
    margin: 0 0 12px 0;
  }

  .real-talk__heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(30px, 5vw, 50px);
    font-weight: 550;
    color: var(--color-secondary);
    margin: 0;
  }

  .real-talk__heading em {
    font-style: italic;
    font-weight: 600;
    color: var(--color-ternary);
  }

  .real-talk__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    padding: 0 65px;
  }

  .real-talk__card {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .real-talk__card-image {
    overflow: hidden;
  }

  .real-talk__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .real-talk__card-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .real-talk__card-heading {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--color-secondary);
    margin: 0;
    line-height: 1.3;
  }

  .real-talk__card-body-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0;
  }

  @media (max-width: 768px) {
    .real-talk {
      padding: 64px 24px;
    }

    .real-talk__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>

{% schema %}
{
  "name": "Real Talk",
  "tag": "section",
  "class": "section-index-real-talk",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Real Talk"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Us"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading (italic part)",
      "default": "Real"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Leave blank to use the default image"
        },
        {
          "type": "text",
          "id": "default_asset",
          "label": "Default asset filename",
          "info": "Filename from assets/ folder used when no image is picked above. Do not change unless replacing the asset file."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Talk",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Oil on Top? That's Nature at Work.",
            "body": "That layer of oil is just the natural separation of pure nut oils — a beautiful reminder that we never use artificial stabilizers. A quick stir is all it takes.",
            "default_asset": "Index-oil-on-top.png"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Only the Good Calories.",
            "body": "Packed with feel-good fuel from real nuts, seeds, dates, and coconut oil. Rich in omega-3s, vitamins, and protein — no empty calories here.",
            "default_asset": "Index-Good-calories.png"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Short Shelf Life? That's a Good Thing.",
            "body": "Real food doesn't last forever, and neither do our spreads. No preservatives means every spoonful is as fresh and alive as nature intended.",
            "default_asset": "Index-Real-food.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
