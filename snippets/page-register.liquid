{%- liquid
  assign section_id = section_id | default: 'auth'
  assign show_banner = show_banner | default: true, allow_false: true
  assign compact = compact | default: false, allow_false: true
  assign forms_only = forms_only | default: false, allow_false: true
  assign use_shopify_account = false
  if shop.customer_accounts_enabled
    assign use_shopify_account = true
  endif
  if routes.storefront_login_url != blank
    assign use_shopify_account = true
  endif
-%}

{%- unless forms_only -%}
  {%- if show_banner -%}
    <div class="auth-banner">
      <div class="auth-banner__content">
        <h1 class="auth-banner__title">Create Account</h1>
        <p class="auth-banner__subtitle">
          <a href="{{ routes.root_url }}">Home</a> / Register
        </p>
      </div>
    </div>
  {%- endif -%}

  <div class="auth-page{% if compact %} auth-page--compact{% endif %}" data-auth-root="{{ section_id }}" data-initial-view="register">
    <div class="auth-page__inner">
      {%- render 'page-login', section_id: section_id, show_banner: false, forms_only: true -%}
{%- endunless -%}

{%- if use_shopify_account -%}
  <div class="auth-card" id="{{ section_id }}-register-section" data-auth-panel="register"{% if forms_only %} hidden{% endif %}>
    <h2 class="auth-card__title">{{ 'customer.register.title' | t }}</h2>
    <p class="auth-card__subtitle">Enter your email to receive a verification code</p>

    <form class="auth-email-form" data-auth-email-form novalidate>
      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RegisterEmail">{{ 'customer.login.email' | t }}</label>
        <input
          class="auth-input"
          type="email"
          id="{{ section_id }}-RegisterEmail"
          name="email"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          placeholder="you@example.com"
          required
        >
      </div>

      <button type="submit" class="auth-btn">{{ 'customer.register.submit' | t }}</button>
    </form>

    <div class="auth-links">
      <button type="button" class="auth-link auth-link--btn" data-auth-show="login">
        Already have an account? {{ 'customer.login.sign_in' | t }}
      </button>
    </div>
  </div>

{%- else -%}
  <div class="auth-card" id="{{ section_id }}-register-section" data-auth-panel="register">
    <h2 class="auth-card__title">Join The Clean Fuel Crew</h2>
    <p class="auth-card__subtitle">Create your account to get started</p>

    {%- form 'create_customer' -%}
      {%- if form.errors -%}
        <div class="auth-errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RegisterFirstName">First name</label>
        <input
          class="auth-input"
          type="text"
          name="customer[first_name]"
          id="{{ section_id }}-RegisterFirstName"
          autocomplete="given-name"
          placeholder="Your first name"
        >
      </div>

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RegisterLastName">Last name</label>
        <input
          class="auth-input"
          type="text"
          name="customer[last_name]"
          id="{{ section_id }}-RegisterLastName"
          autocomplete="family-name"
          placeholder="Your last name"
        >
      </div>

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RegisterEmail">{{ 'customer.login.email' | t }}</label>
        <input
          class="auth-input"
          type="email"
          name="customer[email]"
          id="{{ section_id }}-RegisterEmail"
          autocomplete="email"
          placeholder="you@example.com"
          required
        >
      </div>

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RegisterPassword">{{ 'customer.login.password' | t }}</label>
        <input
          class="auth-input"
          type="password"
          name="customer[password]"
          id="{{ section_id }}-RegisterPassword"
          autocomplete="new-password"
          placeholder="********"
          required
        >
      </div>

      <button type="submit" class="auth-btn">{{ 'customer.register.submit' | t }}</button>
    {%- endform -%}

    <div class="auth-links">
      <span class="auth-links__hint">Already have an account?</span>
      <button type="button" class="auth-link auth-link--btn" data-auth-show="login">
        {{ 'customer.login.sign_in' | t }}
      </button>
    </div>
  </div>
{%- endif -%}

{%- unless forms_only -%}
    </div>
  </div>
{%- endunless -%}
