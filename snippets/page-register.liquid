<div class="auth-banner">
  <div class="auth-banner__content">
    <h1 class="auth-banner__title">Create Account</h1>
    <p class="auth-banner__subtitle"><a href="{{ routes.root_url }}">Home</a> / Register</p>
  </div>
</div>

<div class="auth-page">
  <div class="auth-page__inner">
    <div class="auth-card">
      <h2 class="auth-card__title">Join The Clean Spread</h2>
      <p class="auth-card__subtitle">Create your account to get started</p>

      {%- form 'create_customer' -%}
        {%- if form.errors -%}
          <div class="auth-errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="auth-field">
          <label class="auth-label" for="RegisterFirstName">First name</label>
          <input
            class="auth-input"
            type="text"
            name="customer[first_name]"
            id="RegisterFirstName"
            autocomplete="given-name"
            placeholder="Your first name"
          >
        </div>

        <div class="auth-field">
          <label class="auth-label" for="RegisterLastName">Last name</label>
          <input
            class="auth-input"
            type="text"
            name="customer[last_name]"
            id="RegisterLastName"
            autocomplete="family-name"
            placeholder="Your last name"
          >
        </div>

        <div class="auth-field">
          <label class="auth-label" for="RegisterEmail">Email address</label>
          <input
            class="auth-input"
            type="email"
            name="customer[email]"
            id="RegisterEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="you@example.com"
            required
          >
        </div>

        <div class="auth-field">
          <label class="auth-label" for="RegisterPassword">Password</label>
          <input
            class="auth-input"
            type="password"
            name="customer[password]"
            id="RegisterPassword"
            autocomplete="new-password"
            placeholder="********"
            required
          >
        </div>
        <button type="submit" class="auth-btn">Create Account</button>
      {%- endform -%}

      <div class="auth-links">
        <span style="font-size:1.4rem; color: rgba(0,0,0,0.45);">Already have an account?</span>
        <a href="{{ routes.account_login_url }}" class="auth-link">Sign in</a>
      </div>
    </div>
  </div>
</div>
