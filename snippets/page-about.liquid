{%- liquid
  assign banner_title = banner_title | default: 'About Us'
  assign banner_subtitle = banner_subtitle | default: ''
  assign story_eyebrow = story_eyebrow | default: 'OUR STORY'
  assign mission_eyebrow = mission_eyebrow | default: 'OUR MISSION'
  assign mission_cta_label = mission_cta_label | default: 'Go to Instagram →'
  assign instagram_url = instagram_url | default: 'https://www.instagram.com/thecleanfuelcrew/'
  assign person_eyebrow = person_eyebrow | default: 'THE PERSON BEHIND THE SPREAD'
  assign person_heading = person_heading | default: 'Amna'
  assign person_image_alt = person_image_alt | default: person_heading

  if banner_image != blank
    assign about_banner_bg = banner_image | image_url: width: 1800
  else
    assign about_banner_bg = 'about-banner.png' | asset_url
  endif

  if mission_image != blank
    assign mission_bg = mission_image | image_url: width: 1800
  else
    assign mission_bg = 'about-mission.png' | asset_url
  endif
-%}
<div
  {% if shopify_attributes != blank %}
    {{ shopify_attributes -}}
  {% endif %}
>
  <div class="about-banner-wrap">
    <div class="about-banner__bg" style="background-image: url('{{ about_banner_bg }}')"></div>
    <div class="about-banner__overlay" aria-hidden="true"></div>
    <div class="page-width about-banner__content">
      <h1 class="about-banner__title">{{ banner_title | escape }}</h1>
      {%- if banner_subtitle != blank -%}
        <p class="about-banner__description">{{ banner_subtitle | escape }}</p>
      {%- endif -%}
    </div>
  </div>

  <section class="about-story">
    <div class="about-story__inner">
      <div class="about-story__text">
        {%- if story_eyebrow != blank -%}
          <p class="about-story__eyebrow">{{ story_eyebrow | escape }}</p>
        {%- endif -%}
        {%- if story_heading != blank -%}
          <div class="about-story__heading rte">{{ story_heading }}</div>
        {%- endif -%}
        {%- if story_body != blank -%}
          <div class="about-story__body rte">{{ story_body }}</div>
        {%- endif -%}
      </div>
      <div class="about-story__image-wrap">
        {%- if story_image != blank -%}
          {{
            story_image
            | image_url: width: 1200
            | image_tag:
              class: 'about-story__image',
              loading: 'lazy',
              widths: '400, 600, 808, 1200',
              sizes: '(min-width: 990px) 48vw, 100vw',
              alt: banner_title
          }}
        {%- else -%}
          <img
            src="{{ 'about-story.png' | asset_url }}"
            alt="{{ banner_title | escape }}"
            class="about-story__image"
            loading="lazy"
            width="808"
            height="650"
          >
        {%- endif -%}
      </div>
    </div>
  </section>

  <div class="about-mission" style="--banner-img: url('{{ mission_bg }}')">
    <div class="about-mission__overlay" aria-hidden="true"></div>
    <div class="about-mission__inner">
      {%- if mission_eyebrow != blank -%}
        <p class="about-mission__eyebrow">{{ mission_eyebrow | escape }}</p>
      {%- endif -%}
      {%- if mission_quote != blank -%}
        <blockquote class="about-mission__quote">&ldquo;{{ mission_quote | escape }}&rdquo;</blockquote>
      {%- endif -%}
      {%- if instagram_url != blank -%}
        <a
          href="{{ instagram_url }}"
          target="_blank"
          rel="noopener noreferrer"
          class="about-mission__cta"
        >
          {{ mission_cta_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <section class="about-person">
    <div class="about-person__inner">
      <div class="about-person__image-wrap">
        {%- if person_image != blank -%}
          {{
            person_image
            | image_url: width: 1200
            | image_tag:
              class: 'about-person__image',
              loading: 'lazy',
              widths: '400, 600, 814, 1200',
              sizes: '(min-width: 990px) 48vw, 100vw',
              alt: person_image_alt
          }}
        {%- else -%}
          <img
            src="{{ 'about-aishwarya.png' | asset_url }}"
            alt="{{ person_image_alt | escape }}"
            class="about-person__image"
            loading="lazy"
            width="814"
            height="550"
          >
        {%- endif -%}
      </div>
      <div class="about-person__text">
        {%- if person_eyebrow != blank -%}
          <p class="about-person__eyebrow">{{ person_eyebrow | escape }}</p>
        {%- endif -%}
        {%- if person_heading != blank -%}
          <h2 class="about-person__heading">{{ person_heading | escape }}</h2>
        {%- endif -%}
        {%- if person_body != blank -%}
          <div class="about-person__body rte">{{ person_body }}</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <style>
    .about-story__eyebrow,
    .about-person__eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-ternary);
      margin: 0 0 0;
    }

    .about-banner-wrap {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 45rem;
      overflow: hidden;
      text-align: center;
    }

    .about-banner__bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      z-index: 0;
    }

    .about-banner__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: rgba(92, 61, 46, 0.65);
    }

    .about-banner__content {
      position: relative;
      z-index: 2;
      padding: 4rem var(--page-margin);
    }

    .about-banner__title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 3vw, 7rem);
      color: #fff;
      margin: 0 0 1.6rem;
      font-weight: 500;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
    }

    .about-banner__description {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(1rem, 1.3vw, 1.3rem);
      color: var(--color-primary);
      line-height: 1.65;
      max-width: 65rem;
      margin: 0 auto;
    }

    .about-story {
      padding: clamp(5rem, 8vw, 9rem) 0;
      background: var(--color-primary);
      overflow: hidden;
      margin-top: 1.2rem;
    }

    .about-story__inner {
      display: grid;
      gap: 0;
      align-items: center;
    }

    @media screen and (min-width: 990px) {
      .about-story__inner {
        grid-template-columns: 1fr 48%;
      }
    }

    .about-story__text {
      padding: 4rem clamp(3rem, 5vw, 8rem) 4rem clamp(2rem, 5vw, 8rem);
    }

    .about-story__heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 4.1vw, 4.6rem);
      color: var(--color-secondary);
      line-height: 1.15;
      text-transform: capitalize;
      margin: 0 0 2rem;
    }

    .about-story__heading p {
      margin: 0;
    }

    .about-story__heading em {
      color: var(--color-ternary);
      font-style: italic;
      font-size: clamp(3.2rem, 3.8vw, 4.3rem);
    }

    .about-story__body {
      font-size: 1.3rem;
      line-height: 1.75;
      color: var(--color-secondary);
      font-weight: 400;
      font-family: 'DM Sans', sans-serif;
    }

    .about-story__body p {
      margin: 0 0 1.6rem;
    }

    .about-story__body p:last-child {
      margin-bottom: 0;
    }

    .about-story__image-wrap {
      overflow: hidden;
      align-self: stretch;
    }

    .about-story__image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      min-height: 40rem;
    }

    .about-mission {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background-image: var(--banner-img);
      background-size: cover;
      background-position: center;
      padding: clamp(5rem, 8vw, 9rem) var(--page-margin);
      color: #fff;
    }

    .about-mission__overlay {
      position: absolute;
      inset: 0;
      background: rgba(92, 61, 46, 0.52);
    }

    .about-mission__inner {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 85rem;
      margin: 0 auto;
    }

    .about-mission__eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.75);
      margin: 0 0 2rem;
    }

    .about-mission__quote {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(2rem, 2.8vw, 2.8rem);
      line-height: 1.45;
      color: #fff;
      margin: 0 0 3rem;
      padding: 0;
      border: none;
    }

    .about-mission__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 4rem;
      padding: 0 2rem;
      background: var(--color-ternary);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: background 0.3s ease;
    }

    .about-mission__cta:hover {
      background: var(--color-secondary);
    }

    .about-person {
      padding: clamp(5rem, 8vw, 9rem) 0;
      background: var(--color-primary);
      overflow: hidden;
    }

    .about-person__inner {
      display: grid;
      gap: 0;
      align-items: center;
    }

    @media screen and (min-width: 990px) {
      .about-person__inner {
        grid-template-columns: 48% 1fr;
      }
    }

    .about-person__image-wrap {
      overflow: hidden;
      align-self: stretch;
    }

    .about-person__image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .about-person__text {
      padding: 4rem clamp(2rem, 5vw, 8rem) 4rem clamp(1rem, 3vw, 6rem);
    }

    .about-person__body {
      font-size: 1.3rem;
      color: rgba(0, 0, 0, 0.6);
      font-weight: 400;
      line-height: 1.75;
      font-family: 'DM Sans', sans-serif;
    }

    .about-person__body p {
      margin: 0 0 1.6rem;
    }

    .about-person__body p:last-child {
      margin-bottom: 0;
    }

    .about-person__heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 3.5vw, 4rem);
      color: var(--color-secondary);
      font-weight: 500;
      margin: 0 0 2rem;
    }
  </style>
</div>
