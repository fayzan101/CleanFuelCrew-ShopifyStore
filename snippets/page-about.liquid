{%- liquid
  assign banner_title = banner_title | default: 'About Us'
  assign banner_subtitle = banner_subtitle | default: 'Clean, nourishing spreads crafted with thoughtfully sourced, real ingredients that you can trust. Loved by families who want better, healthier choices without compromising on taste.'
  assign instagram_url = instagram_url | default: 'https://www.instagram.com/the_clean_spread/'

  if banner_image != blank
    assign about_banner_bg = banner_image | image_url: width: 1800
  else
    assign about_banner_bg = 'about-banner.png' | asset_url
  endif
-%}
<div
  {% if shopify_attributes != blank %}
    {{ shopify_attributes -}}
  {% endif %}
>
  <div class="about-banner-wrap">
    <div class="about-banner__bg" style="background-image: url('{{ about_banner_bg }}')"></div>
    <div class="about-banner__overlay" aria-hidden="true"></div>
    <div class="page-width about-banner__content">
      <h1 class="about-banner__title">{{ banner_title }}</h1>
      {%- if banner_subtitle != blank -%}
        <p class="about-banner__description">{{ banner_subtitle }}</p>
      {%- endif -%}
    </div>
  </div>
  <section class="about-story">
    <div class="about-story__inner">
      <div class="about-story__text">
        <p class="about-story__eyebrow">OUR STORY</p>
        <h2 class="about-story__heading">Made with <span class="about-story__highlight">purpose,</span> eaten with joy</h2>
        <p class="about-story__body">
          Born in a Dubai kitchen from a lifelong craving to snack better — cleanfuelcrew is wholesome food made honest, minimal, and truly delicious.
        </p>
        <p class="about-story__body">
          What began as a personal mission in Dubai to navigate the demands of insulin resistance without giving up a sweet tooth evolved into cleanfuelcrew, a brand focused on providing honest energy. Disappointed by the lack of clean options and tired of "healthy snacks" packed with hidden sugars and chemical additives, our founder started crafting artisanal treats in their own kitchen. cleanfuelcrew emphasizes clean-label integrity, intentionally editing out the fluff so you will never find refined sugars, gluten, dairy, or artificial ingredients in our recipes. Our kitchen script is beautifully simple: sweetened by nature and powered by dates. By pairing premium nuts, seeds, and rich cacao, our mission is to promote mindful eating and bridge the gap between healthy and truly indulgent food. It's time to flip the page on conventional snacks and establish a healthy, joyful lifestyle together.
        </p>
      </div>
      <div class="about-story__image-wrap">
        <img
          src="{{ 'about-story.png' | asset_url }}"
          alt="The Clean Spread products"
          class="about-story__image"
          loading="lazy"
          width="808"
          height="650"
        >
      </div>
    </div>
  </section>

  <div class="about-mission" style="--banner-img: url('{{ 'about-mission.png' | asset_url }}')">
    <div class="about-mission__overlay" aria-hidden="true"></div>
    <div class="about-mission__inner">
      <p class="about-mission__eyebrow">OUR MISSION</p>
      <blockquote class="about-mission__quote">
        "To inspire mindful eating and support families in building a lifestyle rooted in health, taste, and
        togetherness."
      </blockquote>
      <a
        href="{{ instagram_url }}"
        target="_blank"
        rel="noopener noreferrer"
        class="about-mission__cta"
      >
        Go to Instagram →
      </a>
    </div>
  </div>

  <section class="about-person">
    <div class="about-person__inner">
      <div class="about-person__image-wrap">
        <img
          src="{{ 'about-aishwarya.png' | asset_url }}"
          alt="Ayesha, Founder of cleanfuelcrew"
          class="about-person__image"
          loading="lazy"
          width="814"
          height="550"
        >
      </div>
      <div class="about-person__text">
        <p class="about-person__eyebrow">THE PERSON BEHIND THE SPREAD</p>
        <h2 class="about-person__heading">Ayesha</h2>
        <p class="about-person__body">
          A founder first, Ayesha's belief in clean, nourishing ingredients shapes every product she creates. Living in Dubai for over a decade and managing insulin resistance herself, she understands the challenge of finding treats that satisfy cravings without compromise.
          <br>
          <br>
          cleanfuelcrew is her way of sharing that solution with everyone who wants better snacks — full of flavour, naturally sweetened, and made with ingredients they can genuinely trust.
        </p>
      </div>
    </div>
  </section>

  <style>
    .about-story__eyebrow,
    .about-person__eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-ternary);
      margin: 0 0 1.2rem;
    }

    /* Banner */
    .about-banner-wrap {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 45rem;
      overflow: hidden;
      text-align: center;
    }

    .about-banner__bg {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      z-index: 0;
    }

    .about-banner__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    .about-banner__content {
      position: relative;
      z-index: 2;
      padding: 4rem var(--page-margin);
    }

    .about-banner__title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(4rem, 3vw, 7rem);
      color: #fff;
      margin: 0 0 1.6rem;
      font-weight: 500;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
    }

    .about-banner__description {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(1rem, 1.3vw, 1.3rem);
      color: var(--color-primary);
      line-height: 1.65;
      max-width: 65rem;
      margin: 0 auto;
    }

    /* Our Story */
    .about-story {
      padding: clamp(5rem, 8vw, 9rem) 0;
      background: var(--color-primary);
      overflow: hidden;
    }

    .about-story__inner {
      display: grid;
      gap: 0;
      align-items: center;
    }

    @media screen and (min-width: 990px) {
      .about-story__inner {
        grid-template-columns: 1fr 48%;
      }
    }

    .about-story__text {
      padding: 4rem clamp(3rem, 5vw, 8rem) 4rem clamp(2rem, 5vw, 8rem);
    }

    .about-story__heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 4.1vw, 4.6rem);
      color: var(--color-secondary);
      line-height: 1.15;
      text-transform: capitalize;
      margin: 0 0 2rem;
    }

    .about-story__highlight {
      color: var(--color-ternary);
      font-style: italic;
      font-size: clamp(3.2rem, 3.8vw, 4.3rem);
    }

    .about-story__body {
      font-size: 1.3rem;
      line-height: 1.75;
      color: var(--color-secondary);
      margin: 0 0 1.6rem;
      font-weight: 400;
      font-family: 'DM Sans', sans-serif;
    }

    .about-story__body:last-child {
      margin-bottom: 0;
    }

    .about-story__image-wrap {
      overflow: hidden;
      align-self: stretch;
    }

    .about-story__image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      min-height: 40rem;
    }

    /* Our Mission */
    .about-mission {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background-image: var(--banner-img);
      background-size: cover;
      background-position: center;
      padding: clamp(5rem, 8vw, 9rem) var(--page-margin);
      color: #fff;
    }

    .about-mission__overlay {
      position: absolute;
      inset: 0;
      background: rgba(92, 61, 46, 0.52);
    }

    .about-mission__inner {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 85rem;
      margin: 0 auto;
    }

    .about-mission__eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.75);
      margin: 0 0 2rem;
    }

    .about-mission__quote {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(2rem, 2.8vw, 2.8rem);
      line-height: 1.45;
      color: #fff;
      margin: 0 0 3rem;
      padding: 0;
      border: none;
    }

    .about-mission__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 4rem;
      padding: 0 2rem;
      background: var(--color-ternary);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: background 0.3s ease;
    }

    .about-mission__cta:hover {
      background: var(--color-secondary);
    }

    /* The Person */
    .about-person {
      padding: clamp(5rem, 8vw, 9rem) 0;
      background: var(--color-primary);
      overflow: hidden;
    }

    .about-person__inner {
      display: grid;
      gap: 0;
      align-items: center;
    }

    @media screen and (min-width: 990px) {
      .about-person__inner {
        grid-template-columns: 48% 1fr;
      }
    }

    .about-person__image-wrap {
      overflow: hidden;
      align-self: stretch;
    }

    .about-person__image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .about-person__text {
      padding: 4rem clamp(2rem, 5vw, 8rem) 4rem clamp(1rem, 3vw, 6rem);
    }

    .about-person__body {
      font-size: 1.3rem;
      color: rgba(0, 0, 0, 0.6);
      font-weight: 400;
      line-height: 1.75;
      font-family: 'DM Sans', sans-serif;
      margin: 0 0 1.6rem;
    }

    .about-person__eyebrow {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-ternary);
      margin: 0 0 1.2rem;
    }

    .about-person__heading {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.8rem, 3.5vw, 4rem);
      color: var(--color-secondary);
      font-weight: 500;
      margin: 0 0 2rem;
    }

    .about-person__body:last-child {
      margin-bottom: 0;
    }
  </style>
</div>
