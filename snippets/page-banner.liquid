{%- liquid
  assign banner_title = banner_title | default: 'Page'
  assign banner_subtitle = banner_subtitle | default: ''
-%}

<section class="page-banner">
  <div class="page-banner__media">
    {%- if banner_image != blank -%}
      {{
        banner_image
        | image_url: width: 1800
        | image_tag:
          class: 'page-banner__image',
          loading: 'eager',
          widths: '750, 1100, 1500, 1800',
          sizes: '100vw',
          alt: banner_title
      }}
    {%- else -%}
      <div class="page-banner__image page-banner__image--placeholder" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="page-banner__overlay" aria-hidden="true"></div>

  <div class="page-width page-banner__content">
      <h1 class="page-banner__title">{{ banner_title | escape }}</h1>
    {%- if banner_subtitle != blank -%}
      <p class="page-banner__eyebrow">{{ banner_subtitle | escape }}</p>
    {%- endif -%}
  </div>
</section>

{% style %}
  .page-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 450px;
    overflow: hidden;
    color: #fff;
    margin-bottom: var(--section-spacing);
  }

  @media screen and (min-width: 750px) {
    .page-banner {
      min-height: 450px;
    }
  }

  @media screen and (min-width: 990px) {
    .page-banner {
      min-height: 450px;
    }
  }

  .page-banner__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-banner__image--placeholder {
    background: linear-gradient(135deg, var(--color-secondary) 0%, #7a5a4e 100%);
  }

  .page-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(92, 61, 46, 0.55) 0%,
      rgba(92, 61, 46, 0.4) 100%
    );
  }

  .page-banner__content {
    position: relative;
    z-index: 2;
    width: 100%;
    text-align: center;
    padding: 4rem var(--page-margin);
  }

  .page-banner__title {
    margin: 0;
    margin-top: 45px;
    color: #fff;
    font-family: "Rubik", sans-serif;
    font-size: 36px;
    font-weight: 500;
    line-height: 1.15;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
  }

  .page-banner__eyebrow {
    margin: 1.2rem 0 0;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
  }

  @media screen and (max-width: 749px) {
    .page-banner {
      min-height: 0;
      display: block;
    }

    .page-banner__image {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      object-position: center center;
      background: var(--color-secondary);
    }

    .page-banner__media {
      position: relative;
    }

    .page-banner__overlay {
      display: none;
    }

    .page-banner__content {
      position: relative;
      padding: 1.2rem 1.6rem 0;
    }

    .page-banner__title {
      margin-top: 0;
      font-size: clamp(2rem, 6vw, 2.8rem);
      line-height: 1.1;
    }

    .page-banner__eyebrow {
      margin-top: 0.6rem;
      font-size: 1rem;
      letter-spacing: 0.1em;
    }
  }
{% endstyle %}