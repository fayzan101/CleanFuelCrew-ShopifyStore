<div class="section recipes-page"{% if shopify_attributes != blank %} {{ shopify_attributes }}{% endif %}>
  <div class="page-width">
    <h1 class="page-heading">{{ page.title | escape }}</h1>
  </div>

  <div class="page-width recipes-page__inner">
    <p class="recipes-page__intro">
      Simple, wholesome recipes made with our spreads. Click a recipe to see ingredients and steps.
    </p>

    <ul class="recipe-grid" role="list">
      <li class="recipe-card">
        <details class="recipe-card__details">
          <summary class="recipe-card__summary">
            <div class="recipe-card__media">
              <div class="recipe-card__image recipe-card__image--placeholder" aria-hidden="true"></div>
            </div>
            <div class="recipe-card__header">
              <span class="recipe-card__time">10 min</span>
              <h2 class="recipe-card__title">Honey Almond Toast</h2>
              <p class="recipe-card__excerpt">Crispy sourdough topped with our almond spread and a drizzle of honey.</p>
            </div>
          </summary>
          <div class="recipe-card__body rte">
            <h3>Ingredients</h3>
            <ul>
              <li>2 slices sourdough bread</li>
              <li>3 tbsp almond spread</li>
              <li>1 tbsp honey</li>
              <li>Flaky sea salt</li>
            </ul>
            <h3>Instructions</h3>
            <ol>
              <li>Toast the bread until golden.</li>
              <li>Spread generously with almond spread.</li>
              <li>Drizzle with honey and finish with sea salt.</li>
            </ol>
          </div>
        </details>
      </li>

      <li class="recipe-card">
        <details class="recipe-card__details">
          <summary class="recipe-card__summary">
            <div class="recipe-card__media">
              <div class="recipe-card__image recipe-card__image--placeholder" aria-hidden="true"></div>
            </div>
            <div class="recipe-card__header">
              <span class="recipe-card__time">15 min</span>
              <h2 class="recipe-card__title">Peanut Butter Smoothie Bowl</h2>
              <p class="recipe-card__excerpt">A creamy breakfast bowl packed with protein and natural sweetness.</p>
            </div>
          </summary>
          <div class="recipe-card__body rte">
            <h3>Ingredients</h3>
            <ul>
              <li>1 frozen banana</li>
              <li>1/2 cup oat milk</li>
              <li>2 tbsp peanut spread</li>
              <li>Granola and berries to top</li>
            </ul>
            <h3>Instructions</h3>
            <ol>
              <li>Blend banana, milk, and peanut spread until smooth.</li>
              <li>Pour into a bowl.</li>
              <li>Top with granola and fresh berries.</li>
            </ol>
          </div>
        </details>
      </li>

      <li class="recipe-card">
        <details class="recipe-card__details">
          <summary class="recipe-card__summary">
            <div class="recipe-card__media">
              <div class="recipe-card__image recipe-card__image--placeholder" aria-hidden="true"></div>
            </div>
            <div class="recipe-card__header">
              <span class="recipe-card__time">25 min</span>
              <h2 class="recipe-card__title">Chocolate Hazelnut Pancakes</h2>
              <p class="recipe-card__excerpt">Fluffy weekend pancakes with our chocolate hazelnut spread.</p>
            </div>
          </summary>
          <div class="recipe-card__body rte">
            <h3>Ingredients</h3>
            <ul>
              <li>1 cup flour</li>
              <li>1 egg</li>
              <li>3/4 cup milk</li>
              <li>Chocolate hazelnut spread</li>
            </ul>
            <h3>Instructions</h3>
            <ol>
              <li>Mix batter and cook pancakes on a hot pan.</li>
              <li>Stack and spread between each layer.</li>
              <li>Serve warm with extra spread on top.</li>
            </ol>
          </div>
        </details>
      </li>
    </ul>
  </div>
</div>
