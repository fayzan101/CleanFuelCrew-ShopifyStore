{%- liquid
  assign section_id = section_id | default: 'auth'
  assign show_banner = show_banner | default: true, allow_false: true
  assign compact = compact | default: false, allow_false: true
  assign forms_only = forms_only | default: false, allow_false: true
  assign initial_view = initial_view | default: 'login'
  assign use_shopify_account = false
  if shop.customer_accounts_enabled
    assign use_shopify_account = true
  endif
  if routes.storefront_login_url != blank
    assign use_shopify_account = true
  endif
-%}

{%- unless forms_only -%}
  {%- if show_banner -%}
    <div class="auth-banner">
      <div class="auth-banner__content">
        <h1 class="auth-banner__title">My Account</h1>
        <p class="auth-banner__subtitle">
          <a href="{{ routes.root_url }}">Home</a> / Login
        </p>
      </div>
    </div>
  {%- endif -%}

  <div class="auth-page{% if compact %} auth-page--compact{% endif %}" data-auth-root="{{ section_id }}"{% if initial_view != 'login' %} data-initial-view="{{ initial_view }}"{% endif %}>
    <div class="auth-page__inner">
{%- endunless -%}

{%- if use_shopify_account -%}
  <div class="auth-card" id="{{ section_id }}-login-section" data-auth-panel="login"{% unless initial_view == 'login' %} hidden{% endunless %}>
    <h2 class="auth-card__title">Welcome Back</h2>
    <p class="auth-card__subtitle">Enter your email to receive a verification code</p>

    <form class="auth-email-form" data-auth-email-form novalidate>
      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-CustomerEmail">{{ 'customer.login.email' | t }}</label>
        <input
          class="auth-input"
          type="email"
          id="{{ section_id }}-CustomerEmail"
          name="email"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          placeholder="you@example.com"
          required
        >
      </div>

      <button type="submit" class="auth-btn">{{ 'customer.login.sign_in' | t }}</button>
    </form>

    <div class="auth-links">
      <button type="button" class="auth-link auth-link--btn" data-auth-show="register">
        {{ 'customer.login.create_account' | t }}
      </button>
    </div>
  </div>

{%- else -%}
  <div class="auth-card" id="{{ section_id }}-login-section" data-auth-panel="login"{% unless initial_view == 'login' %} hidden{% endunless %}>
    <h2 class="auth-card__title">Welcome Back</h2>
    <p class="auth-card__subtitle">Sign in to your account</p>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="auth-errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-CustomerEmail">Email address</label>
        <input
          class="auth-input"
          type="email"
          name="customer[email]"
          id="{{ section_id }}-CustomerEmail"
          autocomplete="email"
          placeholder="you@example.com"
          required
        >
      </div>

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-CustomerPassword">{{ 'customer.login.password' | t }}</label>
        <input
          class="auth-input"
          type="password"
          name="customer[password]"
          id="{{ section_id }}-CustomerPassword"
          autocomplete="current-password"
          placeholder="••••••••"
          required
        >
      </div>

      <button type="submit" class="auth-btn">{{ 'customer.login.sign_in' | t }}</button>
    {%- endform -%}

    <div class="auth-links">
      <button type="button" class="auth-link auth-link--btn" data-auth-show="register">
        {{ 'customer.login.create_account' | t }}
      </button>
      <span class="auth-links__divider">·</span>
      <button type="button" class="auth-link auth-link--btn" data-auth-show="recover">
        {{ 'customer.login.forgot_password' | t }}
      </button>
    </div>
  </div>

  <div class="auth-card" id="{{ section_id }}-recover-section" data-auth-panel="recover" hidden>
    <h2 class="auth-card__title">Reset Password</h2>
    <p class="auth-card__subtitle">We'll send a reset link to your email</p>

    {%- form 'recover_customer_password' -%}
      {%- if form.errors -%}
        <div class="auth-errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div class="auth-success" role="status">
          If that email is registered, you'll receive a reset link shortly.
        </div>
      {%- endif -%}

      <div class="auth-field">
        <label class="auth-label" for="{{ section_id }}-RecoverEmail">Email address</label>
        <input
          class="auth-input"
          type="email"
          name="email"
          id="{{ section_id }}-RecoverEmail"
          autocomplete="email"
          placeholder="you@example.com"
          required
        >
      </div>

      <button type="submit" class="auth-btn">Send Reset Link</button>
    {%- endform -%}

    <div class="auth-links">
      <button type="button" class="auth-link auth-link--btn" data-auth-show="login">
        ← Back to login
      </button>
    </div>
  </div>
{%- endif -%}

{%- render 'page-register', section_id: section_id, forms_only: true -%}

{%- unless forms_only -%}
    </div>
  </div>
{%- endunless -%}
