{%- liquid
  assign popular_collection = collections[section.settings.popular_collection]
  if popular_collection == blank
    assign popular_collection = collections.all
  endif

  assign filter_min = section.settings.price_filter_min | times: 100
  assign filter_max = section.settings.price_filter_max | times: 100

  assign active_product_type = ''
  assign active_category_id = ''
  if collection.filters != empty
    for filter in collection.filters
      if filter.param_name == 'filter.p.product_type'
        for active_value in filter.active_values
          assign active_product_type = active_value.label
        endfor
      endif
      if filter.param_name == 'filter.p.t.category'
        for active_value in filter.active_values
          assign active_category_id = active_value.value
        endfor
      endif
    endfor
  endif

  assign store_types = shop.types | sort
  assign seen_category_keys = '||'
  assign filters_source = collections.all
  assign shop_collection_url = collection.url | default: collections.all.url
  assign current_search_q = request.query_string | split: 'q=' | last | split: '&' | first | url_decode
-%}

<aside class="collection-sidebar" data-collection-sidebar>

  <form action="/search" method="get" role="search" class="collection-sidebar__search" data-collection-search>
    <input type="hidden" name="type" value="product">
    <label class="visually-hidden" for="CollectionSidebarSearch">Search entire store</label>
    <input
      type="search"
      name="q"
      id="CollectionSidebarSearch"
      class="collection-sidebar__search-input"
      data-collection-search-input
      placeholder="Search entire store..."
      value="{{ current_search_q | escape }}"
    >
    <button type="submit" class="collection-sidebar__search-btn" aria-label="Search">
      <span class="header__icon-img" style="--icon-url: url('{{ 'search.svg' | asset_url }}');"></span>
    </button>
  </form>

  {%- if section.settings.show_categories -%}
    <div class="collection-sidebar__block">
      <h2 class="collection-sidebar__heading">Categories</h2>
      <ul class="collection-sidebar__list" role="list">

        <li>
          <a href="{{ shop_collection_url }}" {% if active_product_type == blank and active_category_id == blank and current_search_q == blank %}aria-current="page"{% endif %}>All products</a>
        </li>

        {%- comment -%} From storefront filters (Search & Discovery app) {%- endcomment -%}
        {%- for filter in filters_source.filters -%}
          {%- if filter.param_name == 'filter.p.product_type' or filter.param_name == 'filter.p.t.category' -%}
            {%- for value in filter.values -%}
              {%- if value.count > 0 -%}
                {%- liquid
                  assign item_key = filter.param_name | append: ':' | append: value.value | downcase
                  assign item_token = item_key | prepend: '||' | append: '||'
                  assign is_active = false
                  if filter.param_name == 'filter.p.product_type' and value.label == active_product_type
                    assign is_active = true
                  endif
                  if filter.param_name == 'filter.p.t.category' and value.value == active_category_id
                    assign is_active = true
                  endif
                -%}
                {%- unless seen_category_keys contains item_token -%}
                  {%- assign seen_category_keys = seen_category_keys | append: item_key | append: '||' -%}
                  <li>
                    {%- if filter.param_name == 'filter.p.product_type' -%}
                      <a href="{{ shop_collection_url }}?filter.p.product_type={{ value.label | url_param_encode }}" {% if is_active %}aria-current="page"{% endif %}>{{ value.label | escape }}</a>
                    {%- else -%}
                      <a href="{{ shop_collection_url }}?filter.p.t.category={{ value.value | url_param_encode }}" {% if is_active %}aria-current="page"{% endif %}>{{ value.label | escape }}</a>
                    {%- endif -%}
                  </li>
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fallback: shop.types {%- endcomment -%}
        {%- for product_type in store_types -%}
          {%- if product_type != blank -%}
            {%- liquid
              assign item_key = 'filter.p.product_type:' | append: product_type | downcase
              assign item_token = item_key | prepend: '||' | append: '||'
            -%}
            {%- unless seen_category_keys contains item_token -%}
              {%- assign seen_category_keys = seen_category_keys | append: item_key | append: '||' -%}
              <li>
                <a href="{{ shop_collection_url }}?filter.p.product_type={{ product_type | url_param_encode }}" {% if product_type == active_product_type %}aria-current="page"{% endif %}>{{ product_type | escape }}</a>
              </li>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Fallback: taxonomy categories from products {%- endcomment -%}
        {%- for product in collections.all.products -%}
          {%- if product.category != blank and product.category.name != blank -%}
            {%- liquid
              assign item_key = 'filter.p.t.category:' | append: product.category.id | downcase
              assign item_token = item_key | prepend: '||' | append: '||'
            -%}
            {%- unless seen_category_keys contains item_token -%}
              {%- assign seen_category_keys = seen_category_keys | append: item_key | append: '||' -%}
              <li>
                <a href="{{ shop_collection_url }}?filter.p.t.category={{ product.category.id | url_param_encode }}" {% if product.category.id == active_category_id %}aria-current="page"{% endif %}>{{ product.category.name | escape }}</a>
              </li>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

      </ul>
    </div>
  {%- endif -%}

  {%- if section.settings.show_price_filter -%}
    <div class="collection-sidebar__block collection-sidebar__block--price" data-price-filter>
      <h2 class="collection-sidebar__heading">Price Filter</h2>
      <div class="collection-price-filter">
        <div class="collection-price-filter__track">
          <div class="collection-price-filter__fill" data-price-fill></div>
          <input
            type="range"
            class="collection-price-filter__range"
            data-price-range="min"
            min="{{ filter_min }}"
            max="{{ filter_max }}"
            value="{{ filter_min }}"
            aria-label="Minimum price"
          >
          <input
            type="range"
            class="collection-price-filter__range"
            data-price-range="max"
            min="{{ filter_min }}"
            max="{{ filter_max }}"
            value="{{ filter_max }}"
            aria-label="Maximum price"
          >
        </div>
        <div class="collection-price-filter__footer">
          <button type="button" class="collection-price-filter__btn" data-action="price-filter">Filter</button>
          <p class="collection-price-filter__label" data-price-label>
            Price: {{ filter_min | money }} — {{ filter_max | money }}
          </p>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_popular -%}
    <div class="collection-sidebar__block">
      <h2 class="collection-sidebar__heading">{{ section.settings.popular_heading }}</h2>
      <ul class="collection-sidebar__popular" role="list">
        {%- for product in popular_collection.products limit: section.settings.popular_count -%}
          <li class="collection-sidebar__popular-item">
            <a href="{{ product.url }}" class="collection-sidebar__popular-link">
              <span class="collection-sidebar__popular-media">
                {%- if product.featured_media -%}
                  {{
                    product.featured_media
                    | image_url: width: 120
                    | image_tag: loading: 'lazy', widths: '60, 120', sizes: '60px', alt: product.title
                  }}
                {%- endif -%}
              </span>
              <span class="collection-sidebar__popular-text">
                <span class="collection-sidebar__popular-title">{{ product.title | escape }}</span>
                <span class="collection-sidebar__popular-price">{{ product.price | money }}</span>
              </span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

</aside>