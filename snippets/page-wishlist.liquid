<div class="section wishlist-page"{% if shopify_attributes != blank %} {{ shopify_attributes }}{% endif %}>
  {% render 'page-banner',
    banner_title: 'Wishlist',
    banner_subtitle: 'Home / Wishlist',
    banner_image: blank
  %}

  <div class="page-width wishlist-page__inner" data-wishlist-page>
    <p class="wishlist-page__empty" data-wishlist-empty hidden>
      Your wishlist is empty.
      <a href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </p>

    <div class="wishlist-page__table" data-wishlist-table hidden>
      <div class="wishlist-page__head">
        <span class="wishlist-page__head-label wishlist-page__head-label--image">Product</span>
        <span class="wishlist-page__head-label wishlist-page__head-label--title"></span>
        <span class="wishlist-page__head-label wishlist-page__head-label--price">Price</span>
        <span class="wishlist-page__head-label wishlist-page__head-label--cart">Add to cart</span>
        <span class="wishlist-page__head-label wishlist-page__head-label--remove"></span>
      </div>
      <div class="wishlist-page__list" data-wishlist-grid></div>
    </div>
  </div>
</div>
