<div class="section customer-login">
  <div class="page-width">
    <h1>{{ 'customer.login.title' | t }}</h1>

    {% form 'customer_login' %}
      <div class="field">
        <label for="CustomerEmail">{{ 'customer.login.email' | t }}</label>
        <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email">
      </div>

      <div class="field">
        <label for="CustomerPassword">{{ 'customer.login.password' | t }}</label>
        <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password">
      </div>

      <button type="submit" class="button">{{ 'customer.login.sign_in' | t }}</button>

      <p>
        <a href="{{ routes.account_register_url }}">{{ 'customer.login.create_account' | t }}</a>
      </p>
      <p>
        <a href="#recover">{{ 'customer.login.forgot_password' | t }}</a>
      </p>
    {% endform %}

    <div id="recover" class="customer-recover">
      <h2>{{ 'customer.login.forgot_password' | t }}</h2>
      {% form 'recover_customer_password' %}
        <div class="field">
          <label for="RecoverEmail">{{ 'customer.login.email' | t }}</label>
          <input type="email" name="email" id="RecoverEmail" autocomplete="email">
        </div>
        <button type="submit" class="button">{{ 'customer.login.sign_in' | t }}</button>
      {% endform %}
    </div>
  </div>
</div>
