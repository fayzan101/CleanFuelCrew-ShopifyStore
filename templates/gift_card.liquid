{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.balance | money, shop: shop.name }}</title>
    {{ content_for_header }}
  </head>
  <body>
    <main>
      <h1>{{ gift_card.balance | money }}</h1>
      <p>{{ gift_card.code }}</p>
    </main>
  </body>
</html>
